{
    "$schema": "https://schema.railpack.com",
    "provider": "python",
    "steps": {
        "install": {
            "commands": [
                "pip install -r backend/requirements.txt",
                "pip install -e backend/"
            ]
        }
    },
    "deploy": {
        "startCommand": "cd backend && uvicorn app.api.main:app --host 0.0.0.0 --port $PORT"
    }
}